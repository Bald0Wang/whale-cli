# Copy selected values into your shell, ~/.whale/config.json, or deployment environment.
# Never commit a real API key.
# STEP_API_KEY works with Step Plan / step-3.7-flash.
STEP_API_KEY=
# STEPFUN_API_KEY is preferred when LLM_MODEL=step-explore.
STEPFUN_API_KEY=
# Leave blank to select the correct default endpoint from LLM_MODEL.
LLM_BASE_URL=
LLM_MODEL=step-3.7-flash

# Runtime data and the workspace are intentionally separate.
WHALE_HOME=~/.whale
WHALE_WORKSPACE=.
WHALE_HOST=127.0.0.1
WHALE_PORT=8765
