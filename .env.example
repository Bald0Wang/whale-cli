# Copy selected values into your shell, ~/.whale/config.json, or deployment environment.
# Never commit a real API key.
STEP_API_KEY=
LLM_BASE_URL=https://api.stepfun.com/step_plan/v1
LLM_MODEL=step-3.7-flash

# Runtime data and the workspace are intentionally separate.
WHALE_HOME=~/.whale
WHALE_WORKSPACE=.
WHALE_HOST=127.0.0.1
WHALE_PORT=8765
